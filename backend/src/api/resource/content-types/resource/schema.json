{
  "kind": "collectionType",
  "collectionName": "resources",
  "info": {
    "singularName": "resource",
    "pluralName": "resources",
    "displayName": "Resource"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "description": {
      "type": "text"
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "Engineering",
        "Hiring",
        "Placements",
        "AI",
        "Stories",
        "Product",
        "Guides",
        "Docs",
        "Webinars"
      ]
    },
    "resourceType": {
      "type": "enumeration",
      "enum": [
        "article",
        "dataset",
        "playbook",
        "webinar",
        "guide",
        "doc"
      ]
    },
    "glyph": {
      "type": "string"
    },
    "publichedDate": {
      "type": "date"
    },
    "readTime": {
      "type": "string"
    },
    "authorName": {
      "type": "string"
    },
    "authorRole": {
      "type": "string"
    },
    "isFeatured": {
      "type": "boolean"
    },
    "isActive": {
      "type": "boolean"
    },
    "order": {
      "type": "integer"
    },
    "downloadFormat": {
      "type": "string"
    },
    "externalUrl": {
      "type": "string"
    },
    "content": {
      "type": "blocks"
    },
    "coverImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    }
  }
}
