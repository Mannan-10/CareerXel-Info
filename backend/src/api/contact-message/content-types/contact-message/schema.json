{
  "kind": "collectionType",
  "collectionName": "contact_messages",
  "info": {
    "singularName": "contact-message",
    "pluralName": "contact-messages",
    "displayName": "Contact Message"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "firstName": {
      "type": "string"
    },
    "lastName": {
      "type": "string"
    },
    "email": {
      "type": "email"
    },
    "phone": {
      "type": "string"
    },
    "company": {
      "type": "string"
    },
    "role": {
      "type": "string"
    },
    "subject": {
      "type": "string"
    },
    "message": {
      "type": "text"
    },
    "interestType": {
      "type": "enumeration",
      "enum": [
        "demo",
        "pricing",
        "support",
        "partnership",
        "college",
        "employer",
        "candidate",
        "other"
      ]
    },
    "sourcePage": {
      "type": "string"
    },
    "statusType": {
      "type": "enumeration",
      "default": "new",
      "enum": [
        "new",
        "contacted",
        "closed",
        "spam"
      ]
    },
    "consent": {
      "type": "boolean"
    }
  }
}
